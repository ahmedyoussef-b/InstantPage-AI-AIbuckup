{
  "entities": {
    "DocumentMetadata": {
      "title": "DocumentMetadata",
      "description": "Metadata about an uploaded document for the RAG system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "size": { "type": "number" },
        "type": { "type": "string" },
        "chunks": { "type": "number" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "size", "uploadedAt", "userId"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A conversation session between a user and the AI agent.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "An individual message within a chat session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "ai"] },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sessionId", "role", "text", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}/documents/{docId}": {
      "schema": "DocumentMetadata",
      "description": "Collection of document metadata owned by a user."
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "ChatSession",
      "description": "Conversations sessions for a specific user."
    },
    "/users/{userId}/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages belonging to a specific chat session."
    }
  }
}