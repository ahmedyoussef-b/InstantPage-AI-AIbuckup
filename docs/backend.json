
{
  "entities": {
    "DocumentMetadata": {
      "title": "DocumentMetadata",
      "description": "Metadata about an uploaded document for the RAG system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "size": { "type": "number" },
        "type": { "type": "string" },
        "chunks": { "type": "number" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "parentId": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["id", "name", "uploadedAt", "userId"]
    },
    "Folder": {
      "title": "Folder",
      "description": "A directory in the knowledge base.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "parentId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "userId"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}/documents/{docId}": {
      "schema": "DocumentMetadata",
      "description": "Stored documents and their content."
    },
    "/users/{userId}/folders/{folderId}": {
      "schema": "Folder",
      "description": "Directory structure for the user."
    }
  }
}
